# Enterprise 1.0 production foundation
# Copy to .env.local and fill values.

# Runtime mode
NODE_ENV=development

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=documents

# Owner allowlist — these emails get the admin console; everyone else is a client.
# Comma-separated. Authorization also honors Supabase app_metadata.role=admin.
OWNER_EMAIL=

# CORS whitelist for website + internal apps.
# NOTE: CORS_ORIGINS is the canonical key. ALLOWED_ORIGINS remains supported for compatibility.
CORS_ORIGINS=http://localhost:3003,http://127.0.0.1:3003,http://localhost:3001,http://127.0.0.1:3001
ALLOWED_ORIGINS=

# Shared API key for protected enterprise API routes.
# Clients can send this in X-Enterprise-Api-Key or Authorization: Bearer <key>.
ENTERPRISE_API_KEY=

# Optional observability hooks
SENTRY_DSN=

# Production feature gates
AI_GATEWAY_ENABLED=0
NOTIFICATIONS_ENABLED=0

# AI gateway defaults
AI_GATEWAY_DEFAULT_PROVIDER=anthropic
AI_GATEWAY_DEFAULT_MODEL=claude-sonnet-4-5

# Gateway policy controls
AI_GATEWAY_FAILOVER_ENABLED=1
AI_GATEWAY_ROUTING_STRATEGY=health-first
AI_GATEWAY_MAX_RETRIES=2
AI_GATEWAY_TIMEOUT_MS=30000
AI_GATEWAY_BUDGET_DAILY_USD=100
AI_GATEWAY_PROVIDER_ALLOWLIST=anthropic,openai,gemini,azure-openai,ollama
AI_GATEWAY_MODEL_ALLOWLIST=
AI_GATEWAY_KEY_COOLDOWN_SECONDS=30

# Provider credentials (server-side only)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_API_KEY=

# Multi-key pools (optional aliases for failover/rotation)
ANTHROPIC_KEY_PRIMARY=
ANTHROPIC_KEY_SECONDARY=
OPENAI_KEY_PRIMARY=
OPENAI_KEY_SECONDARY=
GEMINI_KEY_PRIMARY=
GEMINI_KEY_SECONDARY=
AZURE_OPENAI_KEY_PRIMARY=
AZURE_OPENAI_KEY_SECONDARY=

# CodexBar integration controls (server-side)
CODEXBAR_ENABLED=0
CODEXBAR_ALLOWED_ORIGINS=http://localhost:3003,http://127.0.0.1:3003
CODEXBAR_SERVICE_API_KEY=
