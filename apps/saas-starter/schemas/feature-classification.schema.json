{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "saas-starter/schemas/feature-classification",
  "title": "FeatureClassification",
  "type": "object",
  "required": ["features", "modules"],
  "properties": {
    "features": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "category", "priority"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "category": {
            "type": "string",
            "enum": ["core", "auth", "billing", "workflow", "content", "integration", "ops"]
          },
          "priority": { "type": "string", "enum": ["must", "should", "may"] }
        }
      }
    },
    "modules": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "integrations": { "type": "array", "items": { "type": "string" } }
  }
}
