{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "saas-starter/handoffs/dna-to-core",
  "title": "DnaToCore",
  "type": "object",
  "required": ["kind", "version", "dna", "builder_jobs"],
  "properties": {
    "kind": { "const": "dna-to-core" },
    "version": { "type": "string" },
    "dna": { "type": "object" },
    "builder_jobs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "stage"],
        "properties": {
          "type": { "type": "string" },
          "stage": { "type": "string" },
          "dependsOn": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "submit_to": {
      "type": "string",
      "const": "grabber-core/product-factory"
    }
  }
}
