{
  "product": {
    "type": "booking",
    "name": "booking-reference",
    "title": "Booking Reference Product",
    "blueprint": "booking",
    "version": "1.0.0"
  },
  "project": {
    "name": "booking-reference",
    "type": "booking",
    "template": "booking",
    "industry": "hospitality",
    "target": "web",
    "business_model": "services",
    "goals": [
      "Let customers book service slots online",
      "Let providers manage availability and calendar",
      "Collect payments and send notifications",
      "Collect reviews and surface search"
    ],
    "users": [
      {
        "role": "customer",
        "goals": ["search providers", "book slot", "pay", "leave review"]
      },
      {
        "role": "provider",
        "goals": ["set availability", "fulfill bookings", "upload assets"]
      },
      {
        "role": "admin",
        "goals": ["manage teams", "view analytics", "configure RBAC"]
      }
    ],
    "critical_flows": [
      "sign up",
      "sign in",
      "search providers",
      "book slot",
      "pay for booking",
      "manage availability",
      "send notification",
      "leave review",
      "upload file",
      "view analytics"
    ],
    "standards_version": "stds-1.0.0",
    "decision_registry": ["EDR-007"]
  },
  "modules": [
    "authentication",
    "teams",
    "rbac",
    "calendar",
    "booking",
    "payments",
    "notifications",
    "reviews",
    "search",
    "files",
    "analytics"
  ],
  "integrations": ["supabase", "stripe", "github", "vercel"],
  "deployment": {
    "provider": "vercel",
    "environments": ["development", "staging", "production"]
  },
  "quality": {
    "security": "high",
    "testing": "required",
    "accessibility": "WCAG-2.1-AA"
  },
  "constraints": {
    "must": [
      "assemble almost entirely from Factory Registry modules",
      "derive artifacts from this DNA",
      "no bespoke feature modules outside catalog"
    ],
    "should": ["module reuse rate >= 0.98"],
    "may": ["optional customers module later"],
    "must_not": [
      "hand-write booking domain logic outside modules/booking",
      "bypass human review when confidence is low"
    ],
    "assumptions": [
      "Sprint 6 reference product — declarative DNA",
      "Grabber Core + Product Factory assemble the app"
    ],
    "unknowns": [],
    "risks": ["calendar timezone edge cases"]
  },
  "authorization": {
    "model": "rbac",
    "roles": ["customer", "provider", "admin"]
  },
  "architecture": {
    "style": "modular-monolith",
    "stack": "crud-dashboard (Next.js + Supabase)"
  },
  "meta": {
    "sprint": 6,
    "kind": "golden_reference",
    "regression": true
  }
}
