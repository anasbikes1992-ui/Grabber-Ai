{
  "module": "authentication",
  "version": "1.0.0",
  "contributes": {
    "modules": [
      "authentication"
    ],
    "entities": [
      "users",
      "sessions"
    ],
    "endpoints": [
      "POST /auth/signup",
      "POST /auth/login",
      "POST /auth/logout"
    ],
    "ui": [
      "LoginForm",
      "SignupForm"
    ],
    "permissions": [
      "auth.self"
    ],
    "integrations": [
      "supabase"
    ]
  }
}
