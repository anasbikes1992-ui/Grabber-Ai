{
  "module": "billing",
  "version": "1.2.0",
  "contributes": {
    "modules": [
      "billing"
    ],
    "entities": [
      "plans",
      "subscriptions"
    ],
    "endpoints": [
      "GET /billing/plans",
      "POST /billing/checkout"
    ],
    "ui": [
      "PlanPicker",
      "BillingPortal"
    ],
    "permissions": [
      "billing.manage"
    ],
    "integrations": [
      "stripe"
    ]
  }
}
