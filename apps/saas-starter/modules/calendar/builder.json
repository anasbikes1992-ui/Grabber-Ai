{
  "id": "module.calendar",
  "name": "calendar",
  "title": "Calendar",
  "version": "1.0.0",
  "kind": "business_module",
  "requires": [
    "authentication"
  ],
  "optional": [
    "booking",
    "notifications"
  ],
  "conflicts": [],
  "supports": [
    "booking",
    "saas",
    "crm"
  ],
  "surfaces": {
