{
  "id": "module.crm",
  "name": "crm",
  "title": "CRM Pipeline",
  "version": "1.0.0",
  "kind": "business_module",
  "requires": [
    "authentication",
    "customers"
  ],
  "optional": [
    "notifications",
    "analytics",
    "teams"
  ],
  "conflicts": [],
  "supports": [
    "crm",
    "saas"
  ],
  "surfaces": {
    "schema": "schema/",
    "api": "api/",
    "frontend": "frontend/",
    "backend": "backend/",
    "tests": "tests/",
    "docs": "docs/"
  },
  "artifacts": {
    "entities": [
      "deals",
      "activities",
      "pipelines"
    ],
    "endpoints": [
      "GET /crm/deals",
      "POST /crm/deals",
      "PATCH /crm/deals/:id/stage"
    ],
    "ui": [
      "PipelineBoard"
    ],
    "permissions": [
      "crm.manage"
    ]
  }
}
