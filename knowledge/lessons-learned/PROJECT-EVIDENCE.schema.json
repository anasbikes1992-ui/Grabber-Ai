{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "grabber/project-evidence",
  "title": "Project recommendation evidence & outcome",
  "type": "object",
  "required": ["engagement_id", "recommendation", "decision"],
  "properties": {
    "engagement_id": { "type": "string" },
    "client_anonymized": { "type": "string" },
    "industry": { "type": "string" },
    "recommendation": { "type": "string" },
    "recommendation_id": { "type": "string" },
    "why": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "evidence": {
      "type": "array",
      "items": { "type": "string" }
    },
    "business_value": {
      "type": "array",
      "items": { "type": "string" }
    },
    "estimated_effort": { "type": "string" },
    "decision": {
      "type": "string",
      "enum": ["accepted", "deferred", "rejected", "partial"]
    },
    "decision_at": { "type": "string", "format": "date-time" },
    "outcome": {
      "type": "object",
      "properties": {
        "useful": { "type": "boolean" },
        "kpi_improved": { "type": ["boolean", "null"] },
        "kpi_notes": { "type": "string" },
        "client_satisfaction": {
          "type": ["number", "null"],
          "minimum": 1,
          "maximum": 5
        },
        "recorded_at": { "type": "string", "format": "date-time" }
      }
    },
    "feeds": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["knowledge_graph", "playbook", "module", "blueprint"]
      },
      "description": "Where this lesson was promoted"
    }
  }
}
