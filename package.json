{
  "name": "grabber-ai-studio",
  "version": "2.0.0",
  "private": true,
  "description": "Grabber AI Studio Core — Software Engineering Operating System",
  "type": "module",
  "workspaces": [
    "runtime",
    "packages/*"
  ],

  "scripts": {
    "test": "npm test --workspace=@grabber-ai-studio/runtime ; npm test --workspace=@grabber/sdk ; npm test --workspace=@grabber/cli ; npm test --workspace=@grabber/enterprise",
    "test:runtime": "npm test --workspace=@grabber-ai-studio/runtime",
    "test:sdk": "npm test --workspace=@grabber/sdk",
    "test:cli": "npm test --workspace=@grabber/cli",
    "test:enterprise": "npm test --workspace=@grabber/enterprise",
    "test:milestones": "npm test --workspace=@grabber/enterprise ; npm test --workspace=@grabber/cli ; npm --prefix apps/saas-starter run test:factory",
    "grabber": "node packages/cli/bin/grabber.js",
    "saas:dev": "npm --prefix apps/saas-starter run dev",
    "saas:typecheck": "npm --prefix apps/saas-starter run typecheck",
    "saas:lint": "npm --prefix apps/saas-starter run lint",
    "saas:build": "npm --prefix apps/saas-starter run build",
    "saas:test:intelligence": "npm --prefix apps/saas-starter run test:intelligence",
    "saas:test:intake": "npm --prefix apps/saas-starter run test:intake",
    "saas:test:integrations": "npm --prefix apps/saas-starter run test:integrations",
    "saas:test:modules": "npm --prefix apps/saas-starter run test:modules",
    "saas:test:booking": "npm --prefix apps/saas-starter run test:booking",
    "saas:test:factory": "npm --prefix apps/saas-starter run test:factory",
    "saas:test:governance": "npm --prefix apps/saas-starter exec -- node --import tsx --test src/factory/governance-gate.test.ts",
    "jarvis:dev": "npm --prefix apps/jarvis-os run dev -- -p 3001",
    "jarvis:build": "npm --prefix apps/jarvis-os run build",
    "jarvis:typecheck": "npm --prefix apps/jarvis-os run typecheck",
    "enterprise:dev": "npm --prefix apps/enterprise run dev -- -p 3002",
    "enterprise:build": "npm --prefix apps/enterprise run build",
    "enterprise:typecheck": "npm --prefix apps/enterprise run typecheck",
    "platform:dev": "npm --prefix apps/enterprise run dev -- -p 3002",
    "platform:build": "npm --prefix apps/enterprise run build",
    "platform:start": "npm --prefix apps/enterprise run start",
    "website:dev": "npm --prefix apps/website run dev",
    "website:build": "npm --prefix apps/website run build",
    "website:typecheck": "npm --prefix apps/website run typecheck",
    "launch:phase1": "echo Run: enterprise:dev (:3002) + website:dev (:3003) — see docs/LAUNCH.md"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED"
}
